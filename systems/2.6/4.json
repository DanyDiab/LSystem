{
    "constants": {
        "MaxDepth": 10,
        "r1": 0.9,
        "r2": 0.8,
        "a1": 35.0,
        "a2": 35.0,
        "wr": 0.707
    },
    "axiom": "A(1, 10)",
    "rules": {
        "A(l, w)": [
            {
                "prob": 1.0,
                "out": "!(w)F(l)[&(a1)B(l*r1, w*wr)]/(180)[&(a2)B(l*r2, w*wr)]"
            }
        ],
        "B(l, w)": [
            {
                "prob": 1.0,
                "out": "!(w)F(l)[+(a1)$B(l*r1, w*wr)][-(a2)$B(l*r2, w*wr)]"
            }
        ]
    }
}